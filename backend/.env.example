# ============================================
# CONFIGURAÇÕES DO DJANGO
# ============================================
# Copie este arquivo para .env e preencha os valores

DEBUG=True
SECRET_KEY=django-insecure-sua-chave-secreta-aqui
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# BANCO DE DADOS (PostgreSQL via Neon.tech)
# ============================================
# Comente esta linha para usar SQLite localmente
# Formato: postgres://USUARIO:SENHA@HOST/NOME_DO_BANCO?sslmode=require
DATABASE_URL=postgres://seu_usuario:sua_senha@seu_host.neon.tech/neondb?sslmode=require

# ============================================
# CORS - Origens Permitidas
# ============================================
# Em desenvolvimento, pode ser True. Em produção, use False.
CORS_ALLOW_ALL_ORIGINS=True
# CORS_ALLOWED_ORIGINS=https://seu-frontend.vercel.app
